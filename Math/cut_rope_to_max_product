class Solution {
  public:
    int maxProduct(int n) {
      
        if(n<=3)
        return n-1;
        
        long long ans;
        
        if(n%3==0)
        ans=pow(3,(n/3));
        
        if(n%3==1)
        {
            ans=pow(3,(n/3)-1)*4;
        }
        if(n%3==2)
        ans=pow(3,(n/3))*2;
        
        return ans;
        
        
    }
};
